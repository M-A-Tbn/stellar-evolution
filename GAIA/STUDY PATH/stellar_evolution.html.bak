<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stellar Evolution Atlas — 1 M☉ Prototype</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" rel="stylesheet">
<script>
MathJax = {
  tex: { inlineMath: [['$','$']], displayMath: [['$$','$$']], processEscapes: true },
  options: { skipHtmlTags: ['script','noscript','style','textarea','pre'] },
  chtml: { scale: 1.0 }
};
</script>
<script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" id="MathJax-script" async></script>
<style>
  :root{
    --bg-a:#05060d;
    --bg-b:#0a0e1c;
    --panel:rgba(15,18,32,0.78);
    --panel-solid:#10131f;
    --border:rgba(255,255,255,0.09);
    --border-strong:rgba(255,255,255,0.16);
    --ink:#e9e7f2;
    --ink-dim:#a6a7c2;
    --ink-faint:#6c6d8a;
    --accent:#f5d76e;
    --accent-soft:#ffe9a8;
    --accent-deep:#b8912c;
    --accent-glow:rgba(245,215,110,0.35);
    --serif:"Source Serif 4", Georgia, serif;
    --sans:"Space Grotesk", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --radius:14px;
  }
  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    margin:0;
    font-family:var(--serif);
    color:var(--ink);
    background:
      radial-gradient(ellipse 60% 40% at 15% -8%, rgba(80,60,150,0.35) 0%, transparent 60%),
      radial-gradient(ellipse 50% 35% at 92% 8%, rgba(30,80,120,0.30) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 50% 110%, rgba(60,30,90,0.25) 0%, transparent 60%),
      linear-gradient(180deg, var(--bg-a) 0%, var(--bg-b) 45%, var(--bg-a) 100%);
    min-height:100vh;
    line-height:1.65;
  }
  .starfield{
    position:fixed; inset:0; z-index:0; pointer-events:none; opacity:0.75;
    background-image:
      radial-gradient(1.4px 1.4px at 8% 12%, #fff, transparent),
      radial-gradient(1px 1px at 22% 68%, #fff, transparent),
      radial-gradient(1.8px 1.8px at 33% 22%, #fff, transparent),
      radial-gradient(1px 1px at 47% 82%, #fff, transparent),
      radial-gradient(1.2px 1.2px at 58% 34%, #fff, transparent),
      radial-gradient(1px 1px at 66% 5%, #fff, transparent),
      radial-gradient(1.6px 1.6px at 74% 58%, #fff, transparent),
      radial-gradient(1px 1px at 81% 88%, #fff, transparent),
      radial-gradient(1.3px 1.3px at 90% 25%, #fff, transparent),
      radial-gradient(1px 1px at 97% 70%, #fff, transparent),
      radial-gradient(1px 1px at 12% 45%, #fff, transparent),
      radial-gradient(1.5px 1.5px at 40% 55%, #fff, transparent);
    background-repeat:repeat;
    background-size: 620px 620px;
  }
  a{ color:var(--accent); }
  ::selection{ background:var(--accent-glow); color:#1a1600; }

  /* ---------- layout shell ---------- */
  .app{ position:relative; z-index:1; display:flex; min-height:100vh; }

  .sidebar{
    position:fixed; left:0; top:0; bottom:0; width:296px; z-index:10;
    background:var(--panel);
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
    border-right:1px solid var(--border);
    overflow-y:auto;
    padding:1.6rem 1.1rem 2rem;
  }
  .sidebar::-webkit-scrollbar{ width:8px; }
  .sidebar::-webkit-scrollbar-thumb{ background:rgba(255,255,255,0.12); border-radius:8px; }

  .brand{ display:flex; align-items:center; gap:0.7rem; padding:0 0.4rem 1.3rem; border-bottom:1px solid var(--border); margin-bottom:1.1rem; }
  .brand-mark{
    width:38px; height:38px; border-radius:50%; flex:0 0 auto;
    background:radial-gradient(circle at 35% 30%, #fff9e0, var(--accent) 45%, var(--accent-deep) 100%);
    box-shadow:0 0 18px 2px var(--accent-glow);
  }
  .brand-title{ font-family:var(--sans); font-weight:700; font-size:1.02rem; letter-spacing:0.01em; }
  .brand-sub{ font-family:var(--sans); font-size:0.72rem; color:var(--ink-dim); letter-spacing:0.06em; text-transform:uppercase; }

  .proto-note{
    font-family:var(--sans); font-size:0.68rem; letter-spacing:0.04em; color:var(--ink-faint);
    background:rgba(245,215,110,0.06); border:1px solid rgba(245,215,110,0.18);
    border-radius:8px; padding:0.5rem 0.6rem; margin:0 0.4rem 1.3rem; line-height:1.5;
  }
  .proto-note b{ color:var(--accent-soft); }
  .proto-bar{ height:4px; border-radius:3px; background:rgba(255,255,255,0.08); margin-top:0.45rem; overflow:hidden; }
  .proto-bar > i{ display:block; height:100%; width:6.7%; background:linear-gradient(90deg, var(--accent-deep), var(--accent)); }

  .nav-group{
    font-family:var(--sans); font-size:0.68rem; font-weight:600; letter-spacing:0.10em; text-transform:uppercase;
    color:var(--ink-faint); margin:1.3rem 0.5rem 0.5rem; padding-top:0.2rem;
  }
  .nav-group:first-of-type{ margin-top:0.2rem; }

  .nav-item{
    display:flex; align-items:center; gap:0.55rem; width:100%; text-align:left;
    background:transparent; border:1px solid transparent; color:var(--ink-dim);
    font-family:var(--sans); font-size:0.85rem; line-height:1.3;
    padding:0.55rem 0.6rem; border-radius:9px; cursor:pointer; margin-bottom:2px;
    transition:background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .nav-item:hover{ background:rgba(255,255,255,0.05); color:var(--ink); }
  .nav-item .dot{
    width:7px; height:7px; border-radius:50%; flex:0 0 auto; background:var(--ink-faint);
  }
  .nav-item.is-live .dot{ background:var(--accent); box-shadow:0 0 6px 1px var(--accent-glow); }
  .nav-item.is-active{
    background:linear-gradient(90deg, rgba(245,215,110,0.14), rgba(245,215,110,0.03));
    border-color:rgba(245,215,110,0.35); color:var(--accent-soft); font-weight:600;
  }
  .nav-item .lbl{ flex:1; }
  .nav-item .soon-tag{
    font-size:0.6rem; letter-spacing:0.05em; text-transform:uppercase; color:var(--ink-faint);
    border:1px solid var(--border-strong); border-radius:5px; padding:1px 5px; flex:0 0 auto;
  }
  .nav-item.is-locked{ color:var(--ink-faint); }
  .nav-item.is-locked:hover{ color:var(--ink-dim); }

  /* ---------- content ---------- */
  .content{ margin-left:296px; flex:1; min-width:0; position:relative; z-index:1; }
  .page{ display:none; }
  .page.is-active{ display:block; animation:fadein 0.35s ease; }
  @keyframes fadein{ from{ opacity:0; transform:translateY(6px);} to{ opacity:1; transform:translateY(0);} }

  /* ---------- hero ---------- */
  .hero{ position:relative; width:100%; height:min(52vh, 460px); min-height:300px; overflow:hidden; }
  .hero-img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 42%; filter:saturate(1.05) contrast(1.03); }
  .hero-overlay{
    position:absolute; inset:0;
    background:
      linear-gradient(180deg, rgba(5,6,13,0.15) 0%, rgba(5,6,13,0.35) 55%, var(--bg-a) 100%),
      linear-gradient(90deg, rgba(5,6,13,0.55) 0%, rgba(5,6,13,0.05) 45%);
  }
  .hero-text{ position:absolute; left:0; right:0; bottom:0; padding:0 2.2rem 1.9rem; max-width:900px; }
  .hero-eyebrow{
    font-family:var(--sans); font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--accent-soft); margin:0 0 0.5rem;
  }
  .hero-text h1{
    font-family:var(--sans); font-weight:700; font-size:clamp(1.9rem, 4vw, 3.1rem);
    margin:0 0 0.55rem; color:#fff; letter-spacing:-0.01em;
    text-shadow:0 2px 24px rgba(0,0,0,0.5);
  }
  .hero-text h1 .sym{ color:var(--accent); }
  .hero-sub{ font-family:var(--serif); font-size:1.02rem; color:#dcd9ea; max-width:640px; margin:0; }

  /* ---------- stat strip ---------- */
  .stat-strip{
    max-width:900px; margin:-2.6rem auto 0; padding:0 2.2rem; position:relative; z-index:2;
    display:grid; grid-template-columns:repeat(auto-fit, minmax(130px,1fr)); gap:0.7rem;
  }
  .stat-card{
    background:var(--panel); border:1px solid var(--border); border-radius:12px;
    padding:0.85rem 0.9rem; backdrop-filter:blur(10px);
  }
  .stat-label{ font-family:var(--sans); font-size:0.64rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:0.3rem; }
  .stat-value{ font-family:var(--sans); font-size:1.18rem; font-weight:600; color:var(--accent-soft); }
  .stat-value small{ font-size:0.7rem; color:var(--ink-dim); font-weight:400; }

  /* ---------- prose ---------- */
  .prose-wrap{ max-width:760px; margin:0 auto; padding:2.6rem 2.2rem 5rem; }
  .prose-wrap h2{
    font-family:var(--sans); font-size:1.5rem; font-weight:700; color:#fff;
    margin:3.1rem 0 0.4rem; padding-top:0.2rem; display:flex; align-items:baseline; gap:0.6rem;
  }
  .prose-wrap h2 .num{ color:var(--accent); font-size:1.1rem; font-weight:600; }
  .prose-wrap h2:first-of-type{ margin-top:0.4rem; }
  .kicker{ font-family:var(--sans); font-size:0.78rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint); margin:0 0 1.6rem; }
  .prose-wrap h3{ font-family:var(--sans); font-size:1.06rem; font-weight:600; color:var(--accent-soft); margin:1.7rem 0 0.5rem; }
  .prose-wrap p{ margin:0 0 1.05rem; color:#d9d7e6; font-size:1.01rem; }
  .prose-wrap p b, .prose-wrap li b{ color:#fff; font-weight:600; }
  .prose-wrap ul, .prose-wrap ol{ color:#d9d7e6; padding-left:1.3rem; margin:0 0 1.1rem; }
  .prose-wrap li{ margin-bottom:0.4rem; }
  hr.rule{ border:none; border-top:1px solid var(--border); margin:2.4rem 0; }

  .callout{
    border-left:3px solid var(--accent); background:rgba(245,215,110,0.06);
    border-radius:0 10px 10px 0; padding:0.9rem 1.1rem; margin:1.3rem 0; font-size:0.94rem;
  }
  .callout .callout-tag{ font-family:var(--sans); font-size:0.68rem; letter-spacing:0.09em; text-transform:uppercase; color:var(--accent-soft); margin-bottom:0.35rem; display:block; }

  .eqn-block{
    background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:10px;
    padding:1rem 1.2rem; margin:1.2rem 0; overflow-x:auto;
  }
  .eqn-note{ font-size:0.88rem; color:var(--ink-dim); margin-top:0.5rem; }

  figure{ margin:2rem 0; }
  figure.fig-wide{ margin-left:calc(-1 * (1px)); }
  .fig-frame{
    background:rgba(255,255,255,0.025); border:1px solid var(--border); border-radius:var(--radius);
    padding:1rem; overflow-x:auto;
  }
  figcaption{ font-family:var(--sans); font-size:0.82rem; color:var(--ink-dim); margin-top:0.7rem; line-height:1.5; }
  figcaption b{ color:var(--ink); }

  /* ---------- timeline ---------- */
  .timeline{ display:flex; width:100%; border-radius:10px; overflow:hidden; height:64px; border:1px solid var(--border); }
  .tl-seg{ position:relative; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; padding:0.2rem 0.25rem; border-right:1px solid rgba(0,0,0,0.35); font-family:var(--sans); }
  .tl-seg:last-child{ border-right:none; }
  .tl-seg .tl-name{ font-size:0.66rem; font-weight:600; letter-spacing:0.02em; }
  .tl-seg .tl-dur{ font-size:0.6rem; opacity:0.85; }
  .tl-premss{ background:#2a2f4a; color:#c7c9e6; }
  .tl-ms{ background:linear-gradient(180deg, var(--accent), var(--accent-deep)); color:#231a02; }
  .tl-sgb{ background:#4a3f66; color:#eae4ff; }
  .tl-rgb{ background:#7a3f66; color:#ffe4f2; }
  .tl-flash{ background:repeating-linear-gradient(45deg,#ff8c5a,#ff8c5a 3px,#c2492a 3px,#c2492a 6px); width:1.2% !important; min-width:8px; }
  .tl-hb{ background:#3f6b7a; color:#e2f6ff; }
  .tl-agb{ background:#3f7a5e; color:#e2fff0; }
  .tl-pn{ background:#7a6a3f; color:#fff6df; }
  .tl-wd{ background:linear-gradient(90deg,#4a4f66,#23263a 85%, transparent); color:#c7c9e6; position:relative; }
  .tl-wd::after{ content:"→ cooling continues"; position:absolute; right:6px; bottom:3px; font-size:0.55rem; color:var(--ink-faint); }
  .tl-legend{ display:flex; flex-wrap:wrap; gap:0.5rem 1rem; margin-top:0.9rem; font-family:var(--sans); font-size:0.72rem; color:var(--ink-dim); }
  .tl-legend span{ display:inline-flex; align-items:center; gap:0.35rem; }
  .tl-legend i{ width:9px; height:9px; border-radius:2px; display:inline-block; }

  /* ---------- HR diagram (feature, full-width) ---------- */
  .hr-feature{ max-width:1240px; margin:0.6rem auto 2.8rem; padding:0 2.2rem; }
  .hr-feature h2{
    font-family:var(--sans); font-size:1.7rem; font-weight:700; color:#fff;
    margin:0.4rem 0 0.5rem; display:flex; align-items:baseline; gap:0.6rem;
  }
  .hr-feature h2 .num{ color:var(--accent); font-size:1.2rem; font-weight:600; }
  .hr-feature > p{ margin:0 0 1.3rem; color:#d9d7e6; font-size:1.04rem; max-width:900px; }
  .hr-feature figure{ margin:0.4rem 0 0; }
  .hr-feature .fig-frame{ padding:1.4rem 1.6rem; }

  .hr-svg{ width:100%; height:auto; display:block; }
  .hr-track-main{ fill:none; stroke:var(--accent); stroke-width:4.4; stroke-linejoin:round; stroke-linecap:round; filter:drop-shadow(0 0 7px rgba(245,215,110,0.5)); }
  .hr-track-bg{ fill:none; stroke:#5b5f80; stroke-width:2; opacity:0.45; }
  .hr-zams{ fill:none; stroke:#8890b0; stroke-width:1.2; stroke-dasharray:5 5; opacity:0.55; }
  .hr-grid{ stroke:rgba(255,255,255,0.06); stroke-width:1; }
  .hr-axis{ stroke:rgba(255,255,255,0.35); stroke-width:1.4; }
  .hr-tick-label{ font-family:var(--sans); font-size:12px; fill:var(--ink-dim); }
  .hr-axis-title{ font-family:var(--sans); font-size:13px; fill:var(--ink-dim); letter-spacing:0.02em; }
  .hr-pt{ fill:var(--accent); stroke:#1a1600; stroke-width:1; }
  .hr-pt-flash{ fill:#ff8c5a; stroke:#1a0f04; stroke-width:1; }
  .hr-label{ font-family:var(--sans); font-size:12.5px; fill:#f1ecff; }
  .hr-label-dim{ font-family:var(--sans); font-size:11px; fill:var(--ink-faint); }

  /* ---------- placeholder pages ---------- */
  .placeholder-wrap{ max-width:760px; margin:0 auto; padding:5rem 2.2rem 6rem; text-align:center; }
  .ph-glyph{ margin:0 auto 1.6rem; opacity:0.8; }
  .ph-badge{
    display:inline-block; font-family:var(--sans); font-size:0.68rem; letter-spacing:0.1em; text-transform:uppercase;
    color:var(--ink-faint); border:1px solid var(--border-strong); border-radius:20px; padding:0.3rem 0.9rem; margin-bottom:1.1rem;
  }
  .placeholder-wrap h1{ font-family:var(--sans); font-size:1.9rem; color:#fff; margin:0 0 0.7rem; }
  .placeholder-wrap .ph-desc{ font-family:var(--serif); color:var(--ink-dim); font-size:1.02rem; max-width:520px; margin:0 auto 1.8rem; }
  .ph-meta{ display:flex; justify-content:center; gap:0.6rem; flex-wrap:wrap; margin-bottom:2.2rem; }
  .ph-meta span{
    font-family:var(--sans); font-size:0.72rem; color:var(--ink-faint); background:rgba(255,255,255,0.04);
    border:1px solid var(--border); border-radius:8px; padding:0.35rem 0.7rem;
  }
  .ph-note{ font-family:var(--sans); font-size:0.82rem; color:var(--ink-faint); border-top:1px solid var(--border); padding-top:1.4rem; }

  .credits{ font-family:var(--sans); font-size:0.74rem; color:var(--ink-faint); text-align:center; margin-top:3rem; padding-top:1.5rem; border-top:1px solid var(--border); }

  @media (max-width: 860px){
    .sidebar{ position:relative; width:100%; height:auto; border-right:none; border-bottom:1px solid var(--border); }
    .content{ margin-left:0; }
    .stat-strip{ margin-top:1.2rem; }
  }
</style>
</head>
<body>
<div class="starfield"></div>
<div class="app">

  <!-- ================= SIDEBAR ================= -->
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-mark"></div>
      <div>
        <div class="brand-title">Stellar Evolution</div>
        <div class="brand-sub">Study Atlas</div>
      </div>
    </div>

    <div class="proto-note">
      <b>Prototype build.</b> One of fifteen pages is fully written — the 1&nbsp;M☉ track. Everything else below is a live, clickable skeleton so the navigation and design can be reviewed before the rest are built.
      <div class="proto-bar"><i></i></div>
    </div>

    <nav aria-label="Study Atlas navigation">
      <p class="nav-group">Part I — Tracks by Mass</p>
      <button class="nav-item is-locked" data-target="page-m0-5"><span class="dot"></span><span class="lbl">0.5 M☉ — Red Dwarf Track</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-live is-active" data-target="page-m1-0"><span class="dot"></span><span class="lbl">1 M☉ — The Sun</span></button>
      <button class="nav-item is-locked" data-target="page-m1-5"><span class="dot"></span><span class="lbl">1.5 M☉ — CNO Transition</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m2-25"><span class="dot"></span><span class="lbl">2.25 M☉ — M<sub>HeF</sub> Boundary</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m3"><span class="dot"></span><span class="lbl">3 M☉ — Blue Loops</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m5"><span class="dot"></span><span class="lbl">5 M☉ — Classic AGB Track</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m9"><span class="dot"></span><span class="lbl">9 M☉ — M<sub>up</sub> Boundary</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m15"><span class="dot"></span><span class="lbl">15 M☉ — Onion-Shell → SN</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-m25"><span class="dot"></span><span class="lbl">25 M☉ — Wolf-Rayet → BH</span><span class="soon-tag">Soon</span></button>

      <p class="nav-group">Part II — The Six Fates</p>
      <button class="nav-item is-locked" data-target="page-brown-dwarf"><span class="dot"></span><span class="lbl">Brown Dwarf (&lt;0.08 M☉)</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-red-dwarf"><span class="dot"></span><span class="lbl">Red Dwarf (0.08–0.5 M☉)</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-sunlike"><span class="dot"></span><span class="lbl">Sun-like Low-Mass (0.5–2 M☉)</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-intermediate"><span class="dot"></span><span class="lbl">Intermediate (2–8 M☉)</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-massive-ns"><span class="dot"></span><span class="lbl">Massive 8–25 M☉ → Neutron Star</span><span class="soon-tag">Soon</span></button>
      <button class="nav-item is-locked" data-target="page-verymassive-bh"><span class="dot"></span><span class="lbl">Very Massive &gt;25 M☉ → Black Hole</span><span class="soon-tag">Soon</span></button>
    </nav>
  </aside>

  <!-- ================= CONTENT ================= -->
  <main class="content">

    <!-- ======================================================= -->
    <!-- PAGE: 1 M☉ — FULLY BUILT                                 -->
    <!-- ======================================================= -->
    <section class="page is-active" id="page-m1-0">

      <div class="hero">
        <img class="hero-img" src="images/stellar/m1.0.jpg" alt="Artist's depiction of a 1 solar mass, G-type main-sequence star">
        <div class="hero-overlay"></div>
        <div class="hero-text">
          <p class="hero-eyebrow">Part I — Tracks by Mass · Star 2 of 9</p>
          <h1>1 M<span class="sym">☉</span> — The Sun's Path</h1>
          <p class="hero-sub">Ten billion quiet years burning hydrogen, a sudden identity crisis at core exhaustion, a violent but invisible flash, a second fire on the horizontal branch, a third double-shelled fire on the asymptotic giant branch, and a slow million-year fade into a crystallizing ember of carbon and oxygen.</p>
        </div>
      </div>

      <div class="stat-strip">
        <div class="stat-card"><div class="stat-label">Effective Temp.</div><div class="stat-value">5,778 K</div></div>
        <div class="stat-card"><div class="stat-label">Luminosity</div><div class="stat-value">1.0 <small>L☉</small></div></div>
        <div class="stat-card"><div class="stat-label">Radius</div><div class="stat-value">1.0 <small>R☉</small></div></div>
        <div class="stat-card"><div class="stat-label">MS Lifetime</div><div class="stat-value">~10 <small>Gyr</small></div></div>
        <div class="stat-card"><div class="stat-label">Core Fuel</div><div class="stat-value">pp-chain <small>(~99%)</small></div></div>
        <div class="stat-card"><div class="stat-label">Endpoint</div><div class="stat-value">CO White Dwarf <small>~0.6 M☉</small></div></div>
      </div>

      <div class="prose-wrap" style="padding-bottom:0;">
        <p class="kicker">A complete evolutionary biography, grounded in the course's Main Sequence, Post-MS, White Dwarf, and Pre-MS notes.</p>
      </div>

      <!-- ============ HR DIAGRAM OVERVIEW — FEATURE ============ -->
